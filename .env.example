# NOTE: the url and the publishable key can be found
# after the 'supabase start' command is executed
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Bot configuration
TELEGRAM_BOT_TOKEN=123456:ABCDEF...
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-webhook-secret
TELEGRAM_BOT_USERNAME=project_hermes_<your_name>_bot
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your_bot_username
NEXT_PUBLIC_MESSENGER_URL=https://m.me/your.page.username

FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
FACEBOOK_VERIFY_TOKEN=your-page-verify-token

GOOGLE_GENERATIVE_AI_API_KEY=<your-api-key>
DEEPGRAM_API_KEY=<your-api-key>

# Optional geocoding configuration
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=your-email@example.com
NOMINATIM_USER_AGENT=project-hermes-geocoding

HERO_YOUTUBE_VIDEO=https://www.youtube.com/
